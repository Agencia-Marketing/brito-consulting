---
import Layout from '../layouts/Layout.astro';
import site from '../content/site.json';
const s = site;
---
<Layout>

<!-- ══ HERO ══ -->
<section id="inicio" style="min-height:100vh;display:flex;align-items:center;padding-top:8rem;padding-bottom:4rem;position:relative;overflow:hidden">
  <div class="hero-glow"></div>
  <div class="container" style="width:100%">
    <div style="display:grid;gap:4rem;align-items:center" class="hero-inner">
      <div>
        <span class="label-tag tag-orange reveal">
          <span class="material-symbols-outlined" style="font-size:.9rem">auto_awesome</span>
          {s.hero.tag}
        </span>
        <h1 class="display reveal" style="margin-top:1rem">
          {s.hero.title} <span class="highlight-text">{s.hero.title_highlight}</span>
        </h1>
        <p style="color:var(--gray-400);margin-top:1.25rem;line-height:1.75;max-width:34rem;font-size:1.05rem" class="reveal">
          {s.hero.description}
        </p>
        <div style="display:flex;gap:1rem;margin-top:2rem;flex-wrap:wrap" class="reveal">
          <a href="#servicios" class="btn btn-orange magnetic">
            <span class="material-symbols-outlined" style="font-size:1rem">rocket_launch</span>
            {s.hero.cta_primary}
          </a>
          <a href="#contacto" class="btn btn-outline magnetic">{s.hero.cta_secondary}</a>
        </div>
      </div>
      <div class="reveal-scale">
        <div style="position:relative;aspect-ratio:1;max-width:420px;margin:0 auto">
          <div class="orb-ring"></div>
          <div class="orb-ring"></div>
          <div class="orb-ring"></div>
          <div style="position:absolute;inset:15%;border-radius:50%;background:var(--bg-card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.5rem">
            <span class="material-symbols-outlined" style="font-size:2.5rem;color:var(--orange)">bolt</span>
            <span style="font-size:.75rem;color:var(--gray-400);font-weight:600">Iniestra Agency</span>
          </div>
          <div class="orb-dot"></div>
          <div class="stat-badge"><div class="dot"></div>{s.hero.badge1}</div>
          <div class="stat-badge"><div class="dot"></div>{s.hero.badge2}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ VALUE PROP ══ -->
<div style="background:#fff;padding:5rem 1.5rem">
  <div class="container value-grid">
    <div class="reveal">
      <span class="label-tag tag-dark">{s.value.tag}</span>
      <h2 class="headline-lg" style="margin-top:.75rem;color:#000">
        {s.value.title} <span style="color:var(--orange);font-style:italic">{s.value.title_highlight}</span>
      </h2>
      <p style="color:#555;margin-top:1rem;line-height:1.75">{s.value.description}</p>
      <a href="#servicios" style="display:inline-flex;align-items:center;gap:.4rem;color:var(--orange);font-weight:700;font-size:.875rem;margin-top:1.5rem">
        {s.value.link_text}
        <span class="material-symbols-outlined" style="font-size:1rem">arrow_forward</span>
      </a>
    </div>
    <div style="display:flex;flex-direction:column;gap:.75rem" class="stagger">
      {s.value.features.map(f => (
        <div style="display:flex;gap:1rem;align-items:flex-start;padding:1rem;border-radius:14px;background:#f9f9f9;border:1px solid #eee">
          <div style="width:40px;height:40px;border-radius:10px;background:var(--orange-dim);display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <span class="material-symbols-outlined" style="color:var(--orange)">{f.icon}</span>
          </div>
          <div>
            <div style="font-weight:700;color:#000;font-size:.9rem;margin-bottom:.2rem">{f.title}</div>
            <div style="font-size:.8rem;color:#666">{f.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ══ SERVICIOS ══ -->
<section id="servicios">
  <div class="container">
    <div class="section-header reveal">
      <span class="label-tag tag-orange">
        <span class="material-symbols-outlined" style="font-size:.9rem">grid_view</span>
        {s.servicios.tag}
      </span>
      <h2 class="headline-lg" style="margin-top:.75rem">
        {s.servicios.title} <span class="highlight-text">{s.servicios.title_highlight}</span>
      </h2>
      <p style="color:var(--gray-400);margin-top:.75rem;max-width:36rem;margin-left:auto;margin-right:auto">{s.servicios.description}</p>
    </div>

    <div class="tabs-nav reveal">
      {s.servicios.tabs.map((tab, i) => (
        <button class={`tab-btn${i===0?' active':''}`} onclick={`switchTab('${tab.id}',this)`}>
          <span class="material-symbols-outlined">{tab.icon}</span>{tab.label}
        </button>
      ))}
    </div>

    {s.servicios.tabs.map((tab, ti) => (
      <div class={`tab-panel${ti===0?' active':''}`} id={`tab-${tab.id}`}>
        <div class="plans-grid">
          {tab.planes.map(plan => (
            <div class={`plan-card${plan.popular?' featured':''}`}>
              {plan.popular && <div class="plan-badge">⚡ Más popular</div>}
              <div class="plan-icon"><span class="material-symbols-outlined">{plan.icon}</span></div>
              <div class="plan-name">{plan.nombre}</div>
              <div class="plan-price">
                <span class="plan-price-num">{plan.precio}</span>
                {plan.periodo && <span class="plan-price-period">{plan.periodo}</span>}
              </div>
              <div class="plan-desc">{plan.desc}</div>
              <div class="plan-features">
                {plan.features.map(f => (
                  <div class={`plan-feat${f.included?'':' off'}`}>
                    <span class="material-symbols-outlined">{f.included?'check':'close'}</span>
                    {f.text}
                  </div>
                ))}
              </div>
              <a href="#contacto" class={`plan-cta${plan.popular?' plan-cta-main':' plan-cta-ghost'}`}>
                {plan.nombre==='Enterprise'?'Contactar':'Solicitar'}
              </a>
            </div>
          ))}
        </div>
      </div>
    ))}

    <p style="color:var(--gray-400);font-size:.875rem;text-align:center;margin-top:2rem" class="reveal">
      {s.servicios.footer_text}
      <a href="#contacto" style="color:var(--orange);font-weight:700">{s.servicios.footer_link}</a> y creamos un plan a medida.
    </p>
  </div>
</section>

<!-- ══ POR QUÉ ══ -->
<section id="por-que" style="background:var(--bg-card)">
  <div class="container porque-grid">
    <div class="reveal">
      <span class="label-tag tag-orange">{s.porque.tag}</span>
      <h2 class="headline-lg" style="margin-top:.75rem">
        {s.porque.title} <span class="highlight-text">{s.porque.title_highlight}</span>
      </h2>
      <p style="color:var(--gray-400);margin-top:1rem;line-height:1.75">{s.porque.description}</p>
      <div style="margin-top:1.5rem;display:flex;align-items:center;gap:1rem;padding:1.25rem;background:var(--bg-elevated);border-radius:16px;border:1px solid var(--border)">
        <div style="width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,var(--orange),#c2410c);flex-shrink:0;display:flex;align-items:center;justify-content:center">
          <span class="material-symbols-outlined" style="color:#fff">person</span>
        </div>
        <div>
          <div style="font-weight:700;font-size:.9rem">{s.porque.founder_name}</div>
          <div style="font-size:.75rem;color:var(--gray-500)">{s.porque.founder_role}</div>
        </div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem" class="stagger">
      {s.porque.features.map(f => (
        <div class="card card-elevated">
          <div class="icon-circle"><span class="material-symbols-outlined">{f.icon}</span></div>
          <h4 style="font-weight:700;margin-top:.75rem;margin-bottom:.3rem">{f.title}</h4>
          <p style="color:var(--gray-400);font-size:.875rem">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ STATS ══ -->
<div class="stats-band">
  <div class="stats-grid stagger">
    {s.stats.map(st => (
      <div class="stat-item">
        <div class="stat-number"><span data-target={st.target} data-suffix={st.suffix}>0</span></div>
        <div class="stat-label">{st.label}</div>
      </div>
    ))}
  </div>
</div>

<!-- ══ PORTFOLIO ══ -->
<section id="portafolio">
  <div class="container">
    <div class="section-header reveal">
      <span class="label-tag tag-orange">
        <span class="material-symbols-outlined" style="font-size:.9rem">photo_library</span>
        {s.portafolio.tag}
      </span>
      <h2 class="headline-lg" style="margin-top:.75rem">
        {s.portafolio.title} <span class="highlight-text">{s.portafolio.title_highlight}</span>
      </h2>
    </div>
    <div class="portfolio-grid stagger">
      {s.portafolio.items.map(item => (
        <div class="portfolio-item">
          <div class="portfolio-placeholder" style={`background:linear-gradient(135deg,${item.color1},${item.color2})`}>
            <span class="material-symbols-outlined">{item.icon}</span>
          </div>
          <div class="portfolio-overlay">
            <div>
              <span class="label-tag tag-orange" style="font-size:.65rem;display:inline-flex;margin-bottom:.5rem">{item.categoria}</span>
              <h3 style="font-family:var(--font-display);font-size:1.1rem">{item.titulo}</h3>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ TESTIMONIOS ══ -->
<section style="background:var(--bg-card);padding:6rem 1.5rem">
  <div class="container">
    <div class="section-header reveal">
      <span class="label-tag tag-orange">{s.testimonios.tag}</span>
      <h2 class="headline-lg" style="margin-top:.75rem">
        {s.testimonios.title} <span class="highlight-text">{s.testimonios.title_highlight}</span>
      </h2>
    </div>
    <div class="testimonials-grid stagger">
      {s.testimonios.items.map(t => (
        <div class="card card-elevated">
          <div style="color:var(--orange);font-size:1rem;letter-spacing:.1em;margin-bottom:1rem">★★★★★</div>
          <p style="font-size:.9rem;color:var(--gray-400);line-height:1.7;margin-bottom:1.25rem">"{t.texto}"</p>
          <div style="display:flex;align-items:center;gap:.75rem">
            <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--orange),var(--bg-elevated));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;flex-shrink:0">{t.iniciales}</div>
            <div>
              <div style="font-weight:700;font-size:.9rem">{t.nombre}</div>
              <div style="font-size:.75rem;color:var(--gray-500)">{t.rol}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ NOSOTROS ══ -->
<section id="nosotros" style="padding:6rem 1.5rem">
  <div class="container nosotros-grid">
    <div class="reveal">
      <span class="label-tag tag-orange">{s.nosotros.tag}</span>
      <h2 class="headline-lg" style="margin-top:.75rem">
        {s.nosotros.title} <span class="highlight-text">{s.nosotros.title_highlight}</span>
      </h2>
      <p style="color:var(--gray-400);margin-top:1rem;line-height:1.75">{s.nosotros.descripcion1}</p>
      <p style="color:var(--gray-400);margin-top:.75rem;line-height:1.75">{s.nosotros.descripcion2}</p>
      <div style="display:flex;gap:1.5rem;margin-top:2rem;flex-wrap:wrap;align-items:center">
        <div>
          <div style="font-family:var(--font-display);font-size:2rem;color:var(--orange)">{s.nosotros.fundacion}</div>
          <div style="font-size:.8rem;color:var(--gray-500)">Fundación</div>
        </div>
        <div style="width:1px;height:40px;background:var(--border)"></div>
        <div>
          <div style="font-family:var(--font-display);font-size:2rem;color:var(--orange)">{s.nosotros.paises}</div>
          <div style="font-size:.8rem;color:var(--gray-500)">Países</div>
        </div>
        <div style="width:1px;height:40px;background:var(--border)"></div>
        <div>
          <div style="font-family:var(--font-display);font-size:2rem;color:var(--orange)">{s.nosotros.clientes}</div>
          <div style="font-size:.8rem;color:var(--gray-500)">Clientes</div>
        </div>
      </div>
    </div>
    <div>
      <div style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--gray-500);margin-bottom:1rem">El equipo</div>
      <div class="team-grid stagger">
        {s.nosotros.equipo.map(m => (
          <div class="team-card">
            <div class="team-avatar">{m.iniciales}</div>
            <div style="font-weight:700;font-size:.9rem;margin-bottom:.25rem">{m.nombre}</div>
            <div style="font-size:.75rem;color:var(--gray-500)">{m.rol}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ══ FAQ ══ -->
<section id="faq" style="background:var(--bg-card);padding:6rem 1.5rem">
  <div class="container">
    <div class="section-header reveal">
      <span class="label-tag tag-orange">{s.faq.tag}</span>
      <h2 class="headline-lg" style="margin-top:.75rem">
        {s.faq.title} <span class="highlight-text">{s.faq.title_highlight}</span>
      </h2>
    </div>
    <div class="faq-list">
      {s.faq.items.map(item => (
        <div class="faq-item">
          <button class="faq-toggle" onclick="toggleFaq(this)">
            {item.pregunta}
            <span class="material-symbols-outlined faq-icon">add</span>
          </button>
          <div class="faq-body"><p>{item.respuesta}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ CONTACTO ══ -->
<section id="contacto" style="padding:6rem 1.5rem;position:relative;overflow:hidden">
  <div class="contact-glow"></div>
  <div class="container" style="position:relative">
    <div class="section-header reveal">
      <span class="label-tag tag-orange">{s.contacto.tag}</span>
      <h2 class="headline-lg" style="margin-top:.75rem">
        {s.contacto.title} <span class="highlight-text">{s.contacto.title_highlight}</span>
      </h2>
      <p style="color:var(--gray-400);margin-top:.75rem">{s.contacto.subtitulo}</p>
    </div>
    <div class="contact-grid">
      <div class="reveal">
        {[
          { icon:'phone',       label:'Teléfono',  value:s.contacto.telefono },
          { icon:'mail',        label:'Email',     value:s.contacto.email },
          { icon:'location_on', label:'Ubicación', value:s.contacto.ubicacion },
          { icon:'schedule',    label:'Horario',   value:s.contacto.horario },
        ].map(item => (
          <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.5rem">
            <div class="contact-icon"><span class="material-symbols-outlined">{item.icon}</span></div>
            <div>
              <div style="font-size:.75rem;color:var(--gray-500);font-weight:600;text-transform:uppercase;letter-spacing:.08em">{item.label}</div>
              <div style="font-weight:700;margin-top:.2rem">{item.value}</div>
            </div>
          </div>
        ))}
        <div class="card card-orange">
          <span class="material-symbols-outlined" style="color:var(--orange);font-size:1.5rem">bolt</span>
          <h4 style="font-weight:700;margin-top:.5rem;margin-bottom:.4rem">{s.contacto.badge_title}</h4>
          <p style="color:var(--gray-400);font-size:.875rem">{s.contacto.badge_desc}</p>
        </div>
      </div>
      <div class="card card-dark reveal">
        <form onsubmit="handleForm(event)">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div style="margin-bottom:1.25rem">
              <label style="display:block;font-size:.8rem;font-weight:700;color:var(--gray-400);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.06em">Nombre *</label>
              <input type="text" class="form-input" placeholder="Tu nombre" required />
            </div>
            <div style="margin-bottom:1.25rem">
              <label style="display:block;font-size:.8rem;font-weight:700;color:var(--gray-400);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.06em">Email *</label>
              <input type="email" class="form-input" placeholder="tu@email.com" required />
            </div>
          </div>
          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:.8rem;font-weight:700;color:var(--gray-400);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.06em">Empresa</label>
            <input type="text" class="form-input" placeholder="Nombre de tu empresa" />
          </div>
          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:.8rem;font-weight:700;color:var(--gray-400);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.06em">Servicio de interés</label>
            <select class="form-select">
              <option value="">Selecciona un servicio...</option>
              {s.contacto.servicios_form.map(sv => <option>{sv}</option>)}
            </select>
          </div>
          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:.8rem;font-weight:700;color:var(--gray-400);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.06em">Mensaje *</label>
            <textarea class="form-textarea" placeholder="Cuéntanos sobre tu proyecto..." required></textarea>
          </div>
          <button type="submit" class="btn btn-orange" style="width:100%;justify-content:center;font-size:.9rem" id="submitBtn">
            <span class="material-symbols-outlined" style="font-size:1rem">send</span>
            Enviar mensaje
          </button>
          <div id="formSuccess" style="display:none;margin-top:1rem;padding:1rem;background:var(--orange-dim);border:1px solid rgba(var(--orange-rgb),.25);border-radius:12px;text-align:center;font-weight:700;color:var(--orange)">
            ✓ Mensaje enviado. Te contactamos pronto.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- ══ CTA ══ -->
<div style="padding:5rem 1.5rem;position:relative;overflow:hidden">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:800px;height:400px;border-radius:50%;background:radial-gradient(ellipse,rgba(var(--orange-rgb),.15) 0%,transparent 70%);pointer-events:none"></div>
  <div class="container">
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:28px;padding:4rem 3rem;text-align:center;position:relative" class="reveal">
      <span class="label-tag tag-orange">{s.cta.tag}</span>
      <h2 class="display" style="margin:.75rem 0 1rem">
        {s.cta.title} <span class="highlight-text">{s.cta.title_highlight}</span>
      </h2>
      <p style="color:var(--gray-400);max-width:32rem;margin:0 auto 2rem;line-height:1.7">{s.cta.description}</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="#contacto" class="btn btn-orange magnetic">
          <span class="material-symbols-outlined" style="font-size:1rem">calendar_month</span>
          {s.cta.cta_primary}
        </a>
        <a href="#servicios" class="btn btn-outline">{s.cta.cta_secondary}</a>
      </div>
    </div>
  </div>
</div>

</Layout>

<style>
  @media(min-width:1024px) {
    .hero-inner    { grid-template-columns: 7fr 5fr !important; }
    .value-grid    { grid-template-columns: 1fr 1fr !important; }
    .porque-grid   { grid-template-columns: 1fr 1fr !important; }
    .nosotros-grid { grid-template-columns: 1fr 1fr !important; }
    .contact-grid  { grid-template-columns: 5fr 7fr !important; }
  }
  .value-grid, .porque-grid, .nosotros-grid, .contact-grid {
    display: grid; gap: 3rem; align-items: center;
  }
  .testimonials-grid { display:grid; gap:1rem; }
  @media(min-width:768px) { .testimonials-grid { grid-template-columns:repeat(3,1fr); } }
</style>

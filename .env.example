# Keystatic — modo GitHub (edición en producción).
# En desarrollo local Keystatic usa modo "local" y NO necesita estas variables.
# Crear una GitHub App y rellenar estos valores en .env (local) y en el hosting.

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Secreto aleatorio para firmar la cookie de sesión (ej: `openssl rand -hex 32`)
KEYSTATIC_SECRET=
# Slug público de la GitHub App (variable expuesta al cliente)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Stripe — clave secreta para el cobro online (Stripe Checkout).
# En dev usa una clave de prueba (sk_test_...). En producción NO se pone aquí:
# se guarda como secret del Worker con `wrangler secret put STRIPE_SECRET_KEY`
# o en Cloudflare Dashboard → Worker → Settings → Variables & Secrets.
STRIPE_SECRET_KEY=
